---
// Nav.astro - top navigation with language switcher
// To add a new language: add it to the LANGS object in the <script> below
// To change nav links: edit the links array here
const links = [
  { href: "#whoami",     label: "whoami"     },
  { href: "#skills",     label: "skills"     },
  { href: "#projects",   label: "projects"   },
  { href: "#experience", label: "timeline"   },
  { href: "#contact",    label: "contact"    },
];
---

<header id="nav">
  <div class="nav-inner">

    <!-- Left: identity -->
    <a href="/" class="nav-brand">
      <span class="nav-bracket">[</span>
      <span class="nav-name">JD</span>
      <span class="nav-cursor">_</span>
      <span class="nav-bracket">]</span>
    </a>

    <!-- Center: links -->
    <nav class="nav-links" aria-label="Main navigation">
      {links.map(l => (
        <a href={l.href} class="nav-link">{l.label}</a>
      ))}
    </nav>

    <!-- Right: language switcher + status -->
    <div class="nav-right">
      <div class="lang-switcher" id="lang-switcher" aria-label="Language switcher">
        <button class="lang-btn" id="lang-toggle" aria-haspopup="true" aria-expanded="false">
          <span class="lang-globe">🌐</span>
          <span class="lang-current" id="lang-current">EN</span>
          <span class="lang-arrow">▾</span>
        </button>
        <div class="lang-dropdown" id="lang-dropdown" role="menu">
          <button class="lang-option active" data-lang="en" role="menuitem">🇺🇸 English</button>
          <button class="lang-option" data-lang="es" role="menuitem">🇪🇸 Español</button>
          <button class="lang-option" data-lang="fr" role="menuitem">🇫🇷 Français</button>
          <button class="lang-option" data-lang="pt" role="menuitem">🇧🇷 Português</button>
          <button class="lang-option" data-lang="ja" role="menuitem">🇯🇵 日本語</button>
          <button class="lang-option" data-lang="zh" role="menuitem">🇨🇳 中文</button>
        </div>
      </div>

      <div class="nav-status">
        <span class="status-dot"></span>
        <span class="status-text" data-i18n="available">Available</span>
      </div>
    </div>

    <!-- Mobile hamburger -->
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>

  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu">
    {links.map(l => (
      <a href={l.href} class="mobile-link">{l.label}</a>
    ))}
  </div>
</header>

<style>
  #nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    background: rgba(8, 11, 20, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    transition: all 0.3s ease;
  }

  #nav.scrolled {
    background: rgba(8, 11, 20, 0.97);
    box-shadow: 0 4px 32px rgba(0,0,0,0.4);
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 40px;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 32px;
  }

  /* Brand */
  .nav-brand {
    font-family: var(--mono);
    font-size: 18px;
    color: var(--violet);
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .nav-bracket { color: var(--text-muted); }
  .nav-name    { color: var(--violet); margin: 0 2px; }
  .nav-cursor  { animation: blink 1.2s infinite; color: var(--coral); }

  /* Links */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
    flex: 1;
  }

  .nav-link {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--text-dim);
    padding: 6px 12px;
    border-radius: var(--radius);
    transition: all var(--transition);
    position: relative;
  }

  .nav-link::before {
    content: '//';
    color: var(--violet);
    margin-right: 4px;
    opacity: 0;
    transition: opacity var(--transition);
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--text);
    background: var(--violet-glow);
  }

  .nav-link:hover::before,
  .nav-link.active::before { opacity: 1; }

  /* Right side */
  .nav-right {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }

  /* Language switcher */
  .lang-switcher {
    position: relative;
  }

  .lang-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text-dim);
    font-family: var(--mono);
    font-size: 12px;
    cursor: pointer;
    transition: all var(--transition);
  }

  .lang-btn:hover {
    border-color: var(--violet);
    color: var(--text);
  }

  .lang-globe { font-size: 14px; }
  .lang-arrow { font-size: 10px; transition: transform 0.2s; }
  .lang-btn[aria-expanded="true"] .lang-arrow { transform: rotate(180deg); }

  .lang-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    min-width: 160px;
    overflow: hidden;
    box-shadow: 0 16px 40px rgba(0,0,0,0.5);
    z-index: 100;
  }

  .lang-dropdown.open { display: block; }

  .lang-option {
    display: block;
    width: 100%;
    padding: 10px 16px;
    background: none;
    border: none;
    color: var(--text-dim);
    font-family: var(--body);
    font-size: 13px;
    text-align: left;
    cursor: pointer;
    transition: all var(--transition);
  }

  .lang-option:hover  { background: var(--violet-glow); color: var(--text); }
  .lang-option.active { color: var(--violet); }

  /* Status indicator */
  .nav-status {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--green);
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--green);
    animation: pulse 2s infinite;
  }

  /* Hamburger */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }

  .nav-hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text-dim);
    border-radius: 2px;
    transition: all 0.3s;
  }

  /* Mobile menu */
  .mobile-menu {
    display: none;
    flex-direction: column;
    padding: 16px 40px 20px;
    border-top: 1px solid var(--border);
    gap: 4px;
  }

  .mobile-menu.open { display: flex; }

  .mobile-link {
    font-family: var(--mono);
    font-size: 14px;
    color: var(--text-dim);
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
    transition: color var(--transition);
  }

  .mobile-link:hover { color: var(--violet); }

  @media (max-width: 768px) {
    .nav-links    { display: none; }
    .nav-hamburger { display: flex; }
    .nav-right    { gap: 10px; }
    .status-text  { display: none; }
    .nav-inner    { padding: 0 20px; }
  }
</style>
